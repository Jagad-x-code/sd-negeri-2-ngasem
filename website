<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:wght@700&display=swap');

  :root {
    --primary: #1a3c34;
    --secondary: #2e7d32;
    --accent: #fbc02d;
    --light: #f9fbf9;
    --dark: #2d3436;
  }

  html, body { 
    margin: 0; padding: 0; 
    font-family: 'Inter', sans-serif; 
    color: var(--dark); background: var(--light); 
    line-height: 1.6; overflow-x: hidden; width: 100%;
  }

  /* 1. Hero Section - FULL Screen */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: white;
    padding: 60px 20px;
    box-sizing: border-box;
    background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), 
                url('https://drive.google.com/thumbnail?sz=w1280&id=1_uuJNLj5NXySxsCzqTtKzpA2dR5LSgKl') center/cover no-repeat;
  }

  .hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.2rem, 8vw, 3.8rem); margin-bottom: 15px; text-shadow: 2px 2px 8px rgba(0,0,0,0.5); }
  .hero p { font-size: clamp(1rem, 4vw, 1.3rem); max-width: 750px; margin-bottom: 35px; font-weight: 300; }
  .btn-main { background: var(--accent); color: var(--dark); padding: 18px 45px; text-decoration: none; border-radius: 50px; font-weight: 700; transition: 0.3s; box-shadow: 0 5px 20px rgba(0,0,0,0.3); }
  .btn-main:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,0,0,0.4); }

  /* 2. Sambutan Section */
  .welcome { 
    padding: 100px 10%; 
    display: grid; 
    grid-template-columns: 1fr 1.5fr; 
    gap: 60px; 
    align-items: center; 
    background: white; 
  }
  .welcome img { 
    width: 100%; 
    max-width: 400px; 
    border-radius: 30px; 
    box-shadow: 25px 25px 0 var(--primary); 
    display: block; margin: 0 auto;
  }
  .welcome h2 { color: var(--primary); font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 2.8rem); margin-top: 0; }

  /* 3. Pillar Section */
  .pillars { padding: 100px 10%; text-align: center; background: var(--light); }
  .pillar-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-top: 50px; }
  .pillar-card { background: white; padding: 50px 35px; border-radius: 20px; box-shadow: 0 15px 40px rgba(0,0,0,0.05); border-bottom: 6px solid var(--secondary); transition: 0.3s; }
  .pillar-card:hover { transform: translateY(-10px); }

  /* 4. News Section */
  .news { padding: 100px 10%; background: #f0f4f1; }
  .news-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
  .news-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; }
  .news-item { background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
  .news-content { padding: 30px; }

  /* 5. Footer */
  .footer { background: var(--primary); color: white; padding: 80px 10% 40px; }
  .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 50px; }
  .footer-bottom { text-align: center; margin-top: 60px; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); font-size: 0.9rem; opacity: 0.6; }

  /* Responsive Adjustments */
  @media (max-width: 992px) {
    .welcome { grid-template-columns: 1fr; text-align: center; padding: 80px 5%; }
    .welcome img { box-shadow: 15px 15px 0 var(--primary); margin-bottom: 30px; }
    .pillars, .news, .footer { padding-left: 5%; padding-right: 5%; }
  }

  @media (max-width: 480px) {
    .hero { min-height: 80vh; }
    .hero h1 { font-size: 2.5rem; }
    .btn-main { width: 90%; text-align: center; padding: 15px 20px; }
  }
</style>
</head>
